data/*
# Keep hand-annotated scene data under version control (rest of data/ stays ignored).
!data/scenarios/
# 'dining' scenario is work-in-progress; keep all of it (data + template) out of the repo for now.
data/scenarios/dining/
templates/dining.json

# Scenario pipeline outputs. Keep source arrangements (tidy.json/messy.json) and
# asset_json_backup/ versioned; these files are regenerated by export/eval runs.
data/scenarios/*/summary_*.json
data/scenarios/*/*/current*
data/scenarios/*/*/goal*
data/scenarios/*/*/reference_goal.png
data/scenarios/*/*/scene.json
data/scenarios/*/*/tabletop_area.json
data/scenarios/*/*/extract_meta.json
data/scenarios/*/*/objects.txt
data/scenarios/*/*/plan.txt
data/scenarios/*/*/our_result.png
data/scenarios/*/*/support_graph.json
data/scenarios/*/*/ta_real_scene.pkl
data/scenarios/*/*/streamline_pipeline.log
data/scenarios/*/*/teleport*.mp4
data/scenarios/*/*/debug_*/
data/scenarios/*/*/object-imgs/
data/scenarios/*/*/recgen_output/
data/scenarios/*/*/sdf_cache/
tmp/*
__pycache__/
*.pyc

# Texture curation scratch (thumbnails, montages, CLIP embeddings, preview renders)
assets/_texture_curate/

# Heavy PBR maps are not versioned; meta.json (tile_m + CC0 source) is kept so the
# library is reproducible. Re-download maps from the source recorded in each meta.json.
assets/textures/**/*.jpg

# Local append-only log of the sizing studio's scale edits; not a shared artifact.
handcraft/scale_edits.jsonl
