data/*
# Keep hand-annotated scene data under version control (rest of data/ stays ignored).
!data/scenarios/
# 'dining' scenario is work-in-progress; keep all of it (data + template) out of the repo for now.
data/scenarios/dining/
templates/dining.json
tmp/*
__pycache__/
*.pyc

# Texture curation scratch (thumbnails, montages, CLIP embeddings, preview renders)
assets/_texture_curate/

# Heavy PBR maps are not versioned; meta.json (tile_m + CC0 source) is kept so the
# library is reproducible. Re-download maps from the source recorded in each meta.json.
assets/textures/**/*.jpg

# Local append-only log of the sizing studio's scale edits; not a shared artifact.
handcraft/scale_edits.jsonl
